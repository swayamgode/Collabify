{
  "meta": {
    "appName": "F.",
    "theme": {
      "mode": "light",
      "colors": {
        "bgPrimary": "#F5F5F7",
        "bgCard": "#FFFFFF",
        "bgSidebar": "#000000",
        "textPrimary": "#000000",
        "textSecondary": "#8E8E93",
        "accent": "#000000",
        "accentText": "#FFFFFF",
        "illustrationBg": "#F0F0F0"
      },
      "fontFamily": "Inter, sans-serif",
      "borderRadius": "24px"
    }
  },
  "layout": {
    "structure": "SidebarLayout",
    "components": [
      {
        "region": "Sidebar",
        "styles": {
          "backgroundColor": "#000000",
          "color": "#FFFFFF",
          "width": "100px",
          "borderRadius": "30px",
          "padding": "40px 0"
        },
        "elements": [
          {
            "type": "Logo",
            "content": "F.",
            "style": "font-size: 32px; font-weight: bold; margin-bottom: 60px;"
          },
          {
            "type": "NavigationMenu",
            "items": [
              { "icon": "Home", "active": true },
              { "icon": "Education", "active": false },
              { "icon": "User", "active": false },
              { "icon": "Mail", "active": false },
              { "icon": "Settings", "active": false }
            ],
            "style": "gap: 40px; display: flex; flex-direction: column; align-items: center;"
          },
          {
            "type": "Action",
            "icon": "Logout",
            "style": "margin-top: auto;"
          }
        ]
      },
      {
        "region": "MainContent",
        "styles": {
          "backgroundColor": "#F5F5F7",
          "padding": "40px",
          "display": "grid",
          "gap": "30px",
          "gridTemplateColumns": "2fr 1fr"
        },
        "sections": [
          {
            "region": "Header",
            "gridArea": "1 / 1 / 2 / 3",
            "components": [
              {
                "type": "WelcomeBanner",
                "styles": {
                  "backgroundColor": "#FFFFFF",
                  "borderRadius": "24px",
                  "padding": "0 40px",
                  "display": "flex",
                  "justifyContent": "space-between",
                  "alignItems": "center"
                },
                "content": {
                  "title": "Hello Josh!",
                  "subtitle": "It's good to see you again.",
                  "illustration": "WavingCharacter"
                }
              },
              {
                "type": "TopActions",
                "styles": { "display": "flex", "gap": "20px", "alignItems": "center" },
                "elements": [
                  { "type": "SearchBar", "placeholder": "Search" },
                  { "type": "NotificationBadge", "count": 1, "icon": "Bell" },
                  { "type": "UserProfile", "image": "user-avatar.jpg" }
                ]
              }
            ]
          },
          {
            "region": "DashboardWidgets",
            "gridArea": "2 / 1 / 3 / 3",
            "display": "grid",
            "gridTemplateColumns": "1.5fr 1fr 1fr",
            "gap": "20px",
            "components": [
              {
                "type": "ActiveCourseCard",
                "styles": {
                   "display": "flex", 
                   "justifyContent": "space-between", 
                   "alignItems": "center",
                   "backgroundColor": "#FFFFFF",
                   "borderRadius": "24px",
                   "padding": "20px"
                },
                "data": {
                  "flag": "🇪🇸",
                  "title": "Spanish B2",
                  "author": "Alejandro Velazquez",
                  "progress": 83
                },
                "actions": [
                  { "label": "Continue", "style": "primary" },
                  { "icon": "ArrowLeft", "style": "circle-outline" },
                  { "icon": "ArrowRight", "style": "circle-outline" }
                ]
              },
              {
                "type": "StatCard",
                "styles": { "backgroundColor": "#FFFFFF", "borderRadius": "24px", "padding": "20px" },
                "data": { "value": 11, "label": "Courses completed" }
              },
              {
                "type": "StatCard",
                "styles": { "backgroundColor": "#FFFFFF", "borderRadius": "24px", "padding": "20px" },
                "data": { "value": 4, "label": "Courses in progress" }
              }
            ]
          },
          {
            "region": "ContentAreaLeft",
            "gridArea": "3 / 1 / 4 / 2",
            "components": [
              {
                "type": "CourseList",
                "title": "Courses",
                "filters": ["All Courses", "The Newest", "Top Rated", "Most Popular"],
                "items": [
                  {
                    "icon": "FigmaLogo",
                    "title": "Learn Figma",
                    "author": "Christopher Morgan",
                    "duration": "6h 30min",
                    "rating": 4.9,
                    "action": "View course"
                  },
                  {
                    "icon": "ApertureIcon",
                    "title": "Analog photography",
                    "author": "Gordon Norman",
                    "duration": "3h 15min",
                    "rating": 4.7,
                    "action": "View course"
                  },
                  {
                    "icon": "InstagramLogo",
                    "title": "Master Instagram",
                    "author": "Sophie Gill",
                    "duration": "7h 40min",
                    "rating": 4.6,
                    "action": "View course"
                  },
                  {
                    "icon": "PencilIcon",
                    "title": "Basics of drawing",
                    "author": "Jean Tate",
                    "duration": "11h 30min",
                    "rating": 4.8,
                    "action": "View course"
                  },
                  {
                    "icon": "PhotoshopLogo",
                    "title": "Photoshop - Essence",
                    "author": "David Green",
                    "duration": "5h 35min",
                    "rating": 4.7,
                    "action": "View course"
                  }
                ]
              }
            ]
          },
          {
            "region": "ContentAreaRight",
            "gridArea": "3 / 2 / 4 / 3",
            "styles": { "display": "flex", "flexDirection": "column", "gap": "20px" },
            "components": [
              {
                "type": "StatisticsChart",
                "title": "Your statistics",
                "filters": [
                  { "label": "Learning Hours", "active": true },
                  { "label": "My Courses", "active": false },
                  { "label": "Weekly", "type": "dropdown" }
                ],
                "data": {
                  "type": "LineChart",
                  "points": [
                    { "day": "mon", "value": 0 },
                    { "day": "tue", "value": 1.5 },
                    { "day": "wed", "value": 2.5 },
                    { "day": "thu", "value": 1.0 },
                    { "day": "fri", "value": 4.0 },
                    { "day": "sat", "value": 3.0 },
                    { "day": "sun", "value": 2.0 }
                  ]
                }
              },
              {
                "type": "PremiumParams",
                "styles": {
                  "backgroundColor": "#F5F5F7", 
                  "borderRadius": "24px", 
                  "padding": "20px",
                  "backgroundImage": "linear-gradient(to bottom right, #ffffff, #f0f0f0)"
                },
                "content": {
                  "title": "Learn even more!",
                  "description": "Unlock premium features only for $9.99 per month.",
                  "illustration": "BrainBook"
                },
                "action": {
                  "label": "Go Premium",
                  "style": "black-button"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
